# =============================================================================
# ursnip-backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set or the server will refuse to start.
# Variables marked [OPTIONAL] have sensible defaults shown in parentheses.

# =============================================================================
# Database
# =============================================================================

# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/ursnip

# [OPTIONAL] Maximum number of connections in the pool (default: 20)
DATABASE_MAX_CONNECTIONS=20

# [OPTIONAL] Minimum number of connections in the pool (default: 5)
DATABASE_MIN_CONNECTIONS=5

# [OPTIONAL] Timeout in seconds for acquiring a connection (default: 5)
DATABASE_CONNECT_TIMEOUT_SECS=5

# [OPTIONAL] Idle timeout in seconds before a connection is closed (default: 300)
DATABASE_IDLE_TIMEOUT_SECS=300

# [OPTIONAL] Statement timeout in seconds (default: 30)
DATABASE_STATEMENT_TIMEOUT_SECS=30

# =============================================================================
# Server
# =============================================================================

# [OPTIONAL] Port to bind the HTTP server (default: 8080)
PORT=8080

# [OPTIONAL] Log level: trace, debug, info, warn, error (default: "info")
LOG_LEVEL=info

# =============================================================================
# Authentication — JWT
# =============================================================================

# [REQUIRED] Secret key for signing JWTs (use a long random string)
JWT_SECRET=your-jwt-secret-here

# =============================================================================
# OAuth — Google
# =============================================================================

# [REQUIRED] Google OAuth 2.0 client ID
GOOGLE_CLIENT_ID=your-google-client-id

# [REQUIRED] Google OAuth 2.0 client secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# OAuth — GitHub
# =============================================================================

# [REQUIRED] GitHub OAuth App client ID
GITHUB_CLIENT_ID=your-github-client-id

# [REQUIRED] GitHub OAuth App client secret
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# OAuth — Redirect
# =============================================================================

# [REQUIRED] Base URL for OAuth redirect URIs (e.g., https://api.ursnip.com)
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# =============================================================================
# AI Provider
# =============================================================================

# [REQUIRED] URL of the AI expansion provider
AI_PROVIDER_URL=https://api.example.com/v1/expand

# [REQUIRED] API key for the AI provider
AI_PROVIDER_KEY=your-ai-provider-key

# [OPTIONAL] Maximum concurrent AI requests (default: 50)
AI_MAX_CONCURRENT_REQUESTS=50

# =============================================================================
# Billing
# =============================================================================

# [REQUIRED] Webhook secret for verifying billing provider signatures
BILLING_WEBHOOK_SECRET=your-billing-webhook-secret

# =============================================================================
# Email — General
# =============================================================================

# [REQUIRED] From address for outgoing emails
EMAIL_FROM_ADDRESS=noreply@ursnip.com

# [OPTIONAL] Display name for outgoing emails (default: "Ursnip")
EMAIL_FROM_NAME=Ursnip

# [REQUIRED] Email provider type: "smtp" or "api"
EMAIL_PROVIDER=smtp

# =============================================================================
# Email — SMTP (required when EMAIL_PROVIDER=smtp)
# =============================================================================

# SMTP server hostname
EMAIL_SMTP_HOST=smtp.example.com

# SMTP server port (usually 587 for STARTTLS or 465 for TLS)
EMAIL_SMTP_PORT=587

# SMTP authentication username
EMAIL_SMTP_USER=your-smtp-user

# SMTP authentication password
EMAIL_SMTP_PASSWORD=your-smtp-password

# =============================================================================
# Email — API (required when EMAIL_PROVIDER=api)
# =============================================================================

# API key for the email service provider
EMAIL_API_KEY=your-email-api-key

# Base URL for the email service API
EMAIL_API_URL=https://api.emailprovider.com/v1/send

# =============================================================================
# Admin Seeding
# =============================================================================

# [REQUIRED] Email for the initial super-admin account (created on first deploy)
SEED_ADMIN_EMAIL=admin@ursnip.com

# [REQUIRED] Password for the initial super-admin account
SEED_ADMIN_PASSWORD=change-me-immediately

# =============================================================================
# CORS
# =============================================================================

# [OPTIONAL] Comma-separated list of allowed origins (default: empty — reject all cross-origin)
CORS_ALLOWED_ORIGINS=

# =============================================================================
# Security / Proxy
# =============================================================================

# [OPTIONAL] Comma-separated list of trusted proxy CIDRs for X-Forwarded-For parsing (default: empty)
TRUSTED_PROXY_CIDRS=

# =============================================================================
# WebSocket
# =============================================================================

# [OPTIONAL] Maximum number of concurrent WebSocket connections (default: 10000)
WS_MAX_CONNECTIONS=10000

# =============================================================================
# Graceful Shutdown
# =============================================================================

# [OPTIONAL] Timeout in seconds for graceful shutdown (default: 30)
SHUTDOWN_TIMEOUT_SECS=30
